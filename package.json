{
  "name": "gemcatalog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
"scripts": {
  "dev": "vite",
  "build": "vite build && node generate-snap-urls.js",
  "postbuild": "react-snap",
  "preview": "vite preview"
},
"reactSnap": {
  "source": "dist",
  "puppeteerArgs": ["--no-sandbox"],
  "inlineCss": true,
  "skipThirdPartyRequests": true
},
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  }
}
